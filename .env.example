# Copy this file to .env and fill in local values.
# NEVER commit the real .env file. NEVER put real secrets in this file.

# --- Application ---
APP_ENV=development
APP_NAME=Continuous KYC Autonomous Auditor
API_V1_PREFIX=/api/v1
LOG_LEVEL=

# --- KYC ingestion ---
KYC_RAW_DIR=data/raw/kyc
KYC_PROCESSED_DIR=data/processed
MAX_KYC_FILE_SIZE_MB=50

# --- Privacy ---
PSEUDONYMIZATION_KEY=

# --- API ingestion ---
API_CONNECT_TIMEOUT_SECONDS=5
API_READ_TIMEOUT_SECONDS=10
MAX_API_RESPONSE_SIZE_MB=10
API_MAX_RETRIES=2
API_SOURCES_JSON=
KYC_PROVIDER_API_TOKEN=

# --- Encryption ---
ENCRYPTION_KEY_ID=kyc-data-key-v1

# --- TLS ---
TLS_CERT_FILE=certs/local/dev-cert.pem
TLS_KEY_FILE=certs/local/dev-key.pem
TLS_PORT=8443
TRUSTED_PROXY_IPS=

# --- Secrets provider ---
SECRETS_PROVIDER=environment

VAULT_ADDR=http://127.0.0.1:8200
VAULT_MOUNT_POINT=secret
VAULT_SECRET_PATH=continuous-kyc
VAULT_AUTH_METHOD=token

# --- Audit logging ---
AUDIT_ENABLED=true
AUDIT_SINK=jsonl
AUDIT_LOG_PATH=backend/var/audit/audit.jsonl

# --- Database ---
DATABASE_URL=

# --- Auth / JWT ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
DEV_AUTH_USERS=

# --- LLM Provider ---
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# --- External Integrations ---
NEWS_API_KEY=your_news_api_key_here
SANCTIONS_DATA_SOURCE_URL=
OFAC_DATA_SOURCE_URL=

# --- Frontend ---
VITE_API_BASE_URL=